# ================================
# Plume Connect — Environment Variables
# Скопируйте в .env и заполните значения
# ================================

# ── AdaptGroup VPN API ──────────────────────────────────
# Ключ API (хранится только на сервере, не в JS-файлах)
ADAPTGROUP_API_KEY=ADAPTBUC6Y36F7JWKZE5ORWKR7G7Q4S2YALOW7SFFVV4VM5K6XR6PMFHQVPN
ADAPTGROUP_API_KEY_ID=1

# ── Vercel KV (Redis) ───────────────────────────────────
# Получить в панели Vercel: Storage → KV → Create Database
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Security ────────────────────────────────────────────
# Секрет для хэширования паролей и сессий (32+ символов)
TOKEN_SECRET=plume_connect_secret_2026_change_me_in_production

# ── App Config ──────────────────────────────────────────
# NODE_ENV=production
# VERCEL_URL=your-project.vercel.app
